# Postgres / pgvector
POSTGRES_DSN=postgresql://rip_agent:rip_agent@localhost:5432/rip_agent

# LlamaParse (ingestion PDF)
LLAMAPARSE_API_KEY=

# Embeddings
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# LiteLLM (génération + LLM-as-judge)
LITELLM_MODEL=openai/gpt-4o
LITELLM_JUDGE_MODEL=openai/gpt-4o
OPENAI_API_KEY=

# Chunking
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# Retrieval
RETRIEVAL_TOP_K_DENSE=20
RETRIEVAL_TOP_K_BM25=20
RETRIEVAL_RRF_K=60

# Génération : budget de tokens pour le contexte injecté dans le prompt
# (les chunks fusionnés sont gardés par ordre de score jusqu'à ce budget)
GENERATION_CONTEXT_MAX_TOKENS=12000

# OpenTelemetry (laisser vide pour exporter en console en dev)
OTEL_EXPORTER_ENDPOINT=
