# Postgres / pgvector
POSTGRES_DSN=postgresql://rip_agent:rip_agent@localhost:5432/rip_agent

# LlamaParse (ingestion PDF)
LLAMAPARSE_API_KEY=

# Embeddings
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# LiteLLM (génération + LLM-as-judge)
LITELLM_MODEL=anthropic/claude-sonnet-4-6
LITELLM_JUDGE_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Chunking
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# Retrieval
RETRIEVAL_TOP_K_DENSE=10
RETRIEVAL_TOP_K_BM25=10
RETRIEVAL_RRF_K=60

# OpenTelemetry (laisser vide pour exporter en console en dev)
OTEL_EXPORTER_ENDPOINT=
